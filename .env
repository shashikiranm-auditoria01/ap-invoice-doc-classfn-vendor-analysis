# ============================================================
# AP Invoice Doc Classfn & Vendor Name Matching — Environment
# ============================================================
# IMPORTANT: Fill in your Metabase credentials before running
# the data extraction scripts. Never commit real credentials.
# ============================================================

# --- Metabase Credentials ---
# Regular instance (metabase.auditoria.ai)
USERNAME_REGULAR=
PASSWORD_REGULAR=

# Enterprise instance (metabase-ent1.auditoria.ai)
USERNAME_ENT=
PASSWORD_ENT=

# --- Query Parameters ---
# Tenant ID (get from tenant.tenant table or Metabase)
TENANT_ID=

# ============================================================
# Backend service (backend/app.py) — OPTIONAL
# Only needed if you run the live backend the frontend calls.
# ============================================================

# Port the backend listens on (frontend points VITE_DATA_API_URL / VITE_SOR_API_URL /
# VITE_ATTACHMENT_API_URL / VITE_EMAIL_BACKEND_URL at http://localhost:<this>).
DATA_BACKEND_PORT=8787

# --- Data source: 'metabase' (default) or 'proddb' ---
# Auto-switches to 'proddb' if DB_URL or TENANT_DB_MAP is set. Set explicitly to force one.
DATA_SOURCE=

# --- Prod DB ---
# Single DB / read-replica holding ALL tenants (SQLAlchemy URL):
DB_URL=
# OR, if prod is SHARDED per tenant, a JSON map of tenant_id → DSN (takes precedence over DB_URL):
# TENANT_DB_MAP={"665247456933969920":"mysql+pymysql://user:pass@shard1:3306/sor","683032998341775360":"mysql+pymysql://user:pass@shard2:3306/sor"}
TENANT_DB_MAP=

# --- AWS S3 (for loading invoice PDFs by extractedFileS3Location / s3Location) ---
# Standard AWS credentials are read from the environment / ~/.aws as usual; set the bucket + region.
S3_BUCKET=
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Email Sender SMTP (Gmail by default) ---
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_STARTTLS=true

