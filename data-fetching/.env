# ============================================================
# AP Invoice Doc Classfn & Vendor Name Matching — Environment
# ============================================================
# IMPORTANT: Fill in your Metabase credentials before running
# the data extraction scripts. Never commit real credentials.
# ============================================================

# --- Metabase Credentials ---
# Regular instance (metabase.auditoria.ai)
USERNAME_REGULAR=
PASSWORD_REGULAR=

# Enterprise instance (metabase-ent1.auditoria.ai)
USERNAME_ENT=
PASSWORD_ENT=

# --- Query Parameters ---
# Tenant ID (get from tenant.tenant table or Metabase)
TENANT_ID=

# ============================================================
# Data-Fetching Backend (server.py) — OPTIONAL
# Only needed if you run the live backend the dashboard can call.
# ============================================================

# Port the backend listens on (dashboard points VITE_DATA_API_URL / VITE_SOR_API_URL /
# VITE_ATTACHMENT_API_URL at http://localhost:<this>).
DATA_BACKEND_PORT=8787

# --- Prod DB (optional) ---
# Leave BLANK to fetch via the Metabase API (default). Set to a SQLAlchemy URL to run the SAME SQL
# directly against the prod DB instead (e.g. mysql+pymysql://user:pass@host:3306/sor).
DB_URL=

# --- AWS S3 (for loading invoice PDFs by extractedFileS3Location / s3Location) ---
# Standard AWS credentials are read from the environment / ~/.aws as usual; set the bucket + region.
S3_BUCKET=
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

