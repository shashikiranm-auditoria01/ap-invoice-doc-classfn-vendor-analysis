# Copy to .env.local to enable the optional live backends. All are OPTIONAL — with none set,
# the dashboard runs fully on the bundled datasets in public/data/.
#
# The data-fetching backend (../data-fetching/server.py) serves all three of the endpoints below.
# Run it with:  cd data-fetching && uvicorn server:app --port 8787   (then use the URLs shown).

# Live data pull. When set, "Get Data" POSTs {kind, scenario, tenant_id, app_def_code, date_from,
# date_to} to {URL}/api/get_data (Metabase now, prod DB when DB_URL is set) instead of bundled .xlsx.
# VITE_DATA_API_URL=http://localhost:8787

# Lazy SOR enrichment. When set, the SOR Hints / Master SOR Record tabs fetch per-document from
# {URL}/api/sor/lookup for docs that arrived without SOR.
# VITE_SOR_API_URL=http://localhost:8787

# Invoice PDF attachments from AWS S3. When set, the details panel can fetch a doc's PDF from
# {URL}/api/attachments?s3Key=<extractedFileS3Location | s3Location>.
# VITE_ATTACHMENT_API_URL=http://localhost:8787/api
# VITE_ATTACHMENT_API_TOKEN=            # optional bearer token

# Email Sender backend (Flask + Gmail SMTP). Defaults to http://localhost:5001.
# VITE_EMAIL_BACKEND_URL=http://localhost:5001
