# Copy to .env.local to point the frontend at the backend. All are OPTIONAL — with none set,
# the dashboard runs fully on the bundled datasets in public/data/ and the Email Sender is disabled.
#
# ONE backend serves everything (data + SOR + attachments + email): ../backend/app.py
#   cd backend && pip install -r requirements.txt && uvicorn app:app --port 8787

# Live data pull: "Get Data" POSTs {kind, scenario, tenant_id, app_def_code, date_from, date_to}
# to {URL}/api/get_data (Metabase, or prod DB when DATA_SOURCE=proddb) instead of bundled .xlsx.
# VITE_DATA_API_URL=http://localhost:8787

# Lazy SOR enrichment for the SOR Hints / Master SOR Record tabs ({URL}/api/sor/lookup).
# VITE_SOR_API_URL=http://localhost:8787

# Invoice PDFs from AWS S3 ({URL}/attachments?s3Key=<extractedFileS3Location | s3Location>).
# Point at {backend}/api so the service's /api/attachments route resolves.
# VITE_ATTACHMENT_API_URL=http://localhost:8787/api
# VITE_ATTACHMENT_API_TOKEN=

# Email Sender (Gmail SMTP) — now served by the SAME backend.
# VITE_EMAIL_BACKEND_URL=http://localhost:8787
